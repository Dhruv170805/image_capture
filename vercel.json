{
  "version": 2,
  "builds": [
    {
      "src": "server/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/app.js"
    },
    {
      "src": "/admin",
      "dest": "client/admin.html"
    },
    {
      "src": "/admin.html",
      "dest": "client/admin.html"
    },
    {
      "src": "/logo.png",
      "dest": "client/logo.png"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "client/index.html"
    }
  ]
}
