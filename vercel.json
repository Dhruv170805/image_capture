{
  "version": 2,
  "functions": {
    "server/app.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/app.js"
    },
    {
      "source": "/admin",
      "destination": "/client/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/client/admin.html"
    },
    {
      "source": "/logo.png",
      "destination": "/client/logo.png"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/client/assets/$1"
    },
    {
      "source": "/((?!api|admin|logo.png|assets).*)",
      "destination": "/client/index.html"
    }
  ]
}
