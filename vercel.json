{
  "version": 2,
  "builds": [
    {
      "src": "server/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/app.js"
    },
    {
      "source": "/admin",
      "destination": "client/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "client/admin.html"
    },
    {
      "source": "/logo.png",
      "destination": "client/logo.png"
    },
    {
      "source": "/assets/(.*)",
      "destination": "client/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "client/index.html"
    }
  ]
}
